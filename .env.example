# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Add these to Netlify → Site settings → Environment Variables

# Supabase (get from: supabase.com → your project → Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxx

# Admin password (shown when clicking "Admin panel")
VITE_ADMIN_PASSWORD=cookr@admin2024

# ─── Backend (Netlify Functions) ──────────────────────────────────────────────

# Supabase service key (for server-side, never expose this in frontend!)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# Resend API key (get from: resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# From email — must be a verified domain on Resend
FROM_EMAIL=attendance@cookr.in

# Power Automate webhook URL for Teams group chat notification
# (Create a flow: HTTP trigger → Post message to Teams group chat)
TEAMS_WEBHOOK_URL=https://prod-xx.westus.logic.azure.com/...

# Your deployed app URL (used in reminder email buttons)
APP_URL=https://cookr-attendance.netlify.app
